{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "jam-desk: build",
      "type": "process",
      "command": "node",
      "args": ["esbuild.js", "--production"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": [],
      "detail": "node esbuild.js --production"
    },
    {
      "label": "jam-desk: watch",
      "type": "process",
      "command": "node",
      "args": ["esbuild.js", "--watch"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "group": "build",
      "problemMatcher": {
        "owner": "esbuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(?:\\s*)([^\\s].*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[jam-desk\\]|watching|esbuild",
          "endsPattern": "\\[jam-desk\\] watching"
        }
      },
      "detail": "node esbuild.js --watch"
    }
  ]
}
