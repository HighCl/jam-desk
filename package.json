{
  "name": "jam-desk",
  "displayName": "Jam Desk — Infinite Canvas",
  "description": "View, manage your terminals inside an infinite canvas. Inspired by the Cate IDE.",
  "version": "0.1.0",
  "publisher": "chamchi",
  "repository": {
    "url": "https://github.com/chamchi0809/jam-desk"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Notebooks",
    "Other"
  ],
  "keywords": [
    "canvas",
    "infinite canvas",
    "whiteboard",
    "spatial",
    "mind map",
    "jam desk"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "jamDesk.open",
        "title": "Open Canvas",
        "category": "Jam Desk",
        "icon": "$(layout)"
      },
      {
        "command": "jamDesk.addNote",
        "title": "Add Note",
        "category": "Jam Desk",
        "icon": "$(note)"
      },
      {
        "command": "jamDesk.addTerminal",
        "title": "Add Terminal",
        "category": "Jam Desk",
        "icon": "$(terminal)"
      },
      {
        "command": "jamDesk.addFile",
        "title": "Add File Card…",
        "category": "Jam Desk",
        "icon": "$(file-add)"
      },
      {
        "command": "jamDesk.addCurrentFile",
        "title": "Add Active File to Canvas",
        "category": "Jam Desk",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "jamDesk.fitToScreen",
        "title": "Fit Canvas to Screen",
        "category": "Jam Desk",
        "icon": "$(screen-full)"
      },
      {
        "command": "jamDesk.autoLayout",
        "title": "Auto-Layout Canvas",
        "category": "Jam Desk",
        "icon": "$(layout-centered)"
      },
      {
        "command": "jamDesk.resetView",
        "title": "Reset Canvas View (Zoom 100%)",
        "category": "Jam Desk"
      },
      {
        "command": "jamDesk.export",
        "title": "Export Canvas to JSON…",
        "category": "Jam Desk"
      },
      {
        "command": "jamDesk.import",
        "title": "Import Canvas from JSON…",
        "category": "Jam Desk"
      },
      {
        "command": "jamDesk.clear",
        "title": "Clear Canvas",
        "category": "Jam Desk"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "jamDesk.addCurrentFile",
          "when": "jamDesk.active && editorIsOpen",
          "group": "navigation@9"
        }
      ],
      "commandPalette": [
        {
          "command": "jamDesk.addNote",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.addTerminal",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.addFile",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.fitToScreen",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.autoLayout",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.resetView",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.export",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.clear",
          "when": "jamDesk.active"
        }
      ]
    },
    "configuration": {
      "title": "Jam Desk",
      "properties": {
        "jamDesk.gridStyle": {
          "type": "string",
          "enum": [
            "dots",
            "lines",
            "none"
          ],
          "default": "dots",
          "description": "Background grid style for the canvas."
        },
        "jamDesk.snapToGrid": {
          "type": "boolean",
          "default": true,
          "description": "Snap nodes to the grid (and to neighbor edges) when moving or resizing. Hold Alt to bypass."
        },
        "jamDesk.zoomSpeed": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 3,
          "description": "Multiplier for wheel / trackpad zoom speed."
        },
        "jamDesk.showMinimap": {
          "type": "boolean",
          "default": true,
          "description": "Show the minimap overview in the corner of the canvas."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@tabler/icons": "^3.44.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
